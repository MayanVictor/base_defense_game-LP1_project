{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Raylib",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "src/the_invasion.cpp",
                "src/Player.cpp",
                "src/Enemy.cpp",
                "src/Bullet.cpp",
                "src/Base.cpp",
                "src/EnemySpawner.cpp",
                "src/Items.cpp",
                "-o",
                "the_invasion.exe",
                "-I${workspaceFolder}/include",
                "-I/ucrt64/include",
                "-L/ucrt64/lib",
                "-lraylib"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}